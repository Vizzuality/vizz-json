{
  "name": "@vizzuality/vizz-json",
  "version": "0.3.2",
  "type": "module",
  "description": "A JSON templating system for geospatial visualization using the @@ prefix convention",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vizzuality/vizz-json.git",
    "directory": "packages/vizz-json"
  },
  "homepage": "https://github.com/Vizzuality/vizz-json/tree/main/packages/vizz-json#readme",
  "bugs": {
    "url": "https://github.com/Vizzuality/vizz-json/issues"
  },
  "keywords": [
    "json",
    "templating",
    "geospatial",
    "deck.gl",
    "maplibre",
    "visualization"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": "./src/index.ts",
    "./react": "./src/react.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./react": {
        "types": "./dist/react.d.ts",
        "import": "./dist/react.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.0.5"
  }
}
