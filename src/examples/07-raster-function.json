{
  "metadata": {
    "title": "@@function — Dynamic URLs",
    "description": "Dynamic tile URL construction via @@function using a TiTiler COG endpoint",
    "tier": "advanced"
  },
  "config": {
    "source": {
      "type": "raster",
      "tiles": [
        {
          "@@function": "setQueryParams",
          "url": "https://titiler.xyz/cog/tiles/WebMercatorQuad/{z}/{x}/{y}.png",
          "query": {
            "url": "https://data.source.coop/alexgleith/gebco-2024/GEBCO_2024.tif",
            "colormap_name": "@@#params.colormap",
            "rescale": "@@#params.rescale"
          }
        }
      ],
      "tileSize": 256
    },
    "styles": [
      {
        "type": "raster",
        "paint": {
          "raster-opacity": "@@#params.opacity"
        },
        "layout": {
          "visibility": "@@#params.visibility"
        }
      }
    ]
  },
  "params_config": [
    {
      "key": "colormap",
      "default": "viridis",
      "options": ["viridis", "plasma", "inferno", "magma", "cividis"]
    },
    { "key": "rescale", "default": "-10000,6000" },
    { "key": "opacity", "default": 1.0, "min": 0, "max": 1, "step": 0.05 },
    {
      "key": "visibility",
      "default": "visible",
      "options": ["visible", "none"]
    }
  ],
  "legend_config": {
    "type": "gradient",
    "items": [
      { "label": "Deep ocean", "value": "#440154" },
      { "label": "Peak", "value": "#fde725" }
    ]
  }
}
