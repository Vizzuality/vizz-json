{
  "metadata": {
    "title": "Data-Driven Circles — zoom + property",
    "description": "Circle radius scales with zoom level and population using nested interpolate expressions",
    "tier": "intermediate"
  },
  "config": {
    "source": {
      "type": "geojson",
      "data": "https://d2ad6b4ur7yvpq.cloudfront.net/naturalearth-3.3.0/ne_50m_admin_0_countries.geojson"
    },
    "styles": [
      {
        "type": "circle",
        "paint": {
          "circle-radius": [
            "interpolate",
            ["linear"],
            ["zoom"],
            2,
            ["*", ["get", "pop_est"], "@@#params.scale_low"],
            8,
            ["*", ["get", "pop_est"], "@@#params.scale_high"]
          ],
          "circle-color": "@@#params.color",
          "circle-opacity": "@@#params.opacity"
        },
        "layout": {
          "visibility": "@@#params.visibility"
        }
      }
    ]
  },
  "params_config": [
    { "key": "scale_low", "default": 0.000001 },
    { "key": "scale_high", "default": 0.00001 },
    { "key": "color", "default": "#3b82f6", "group": "legend" },
    { "key": "opacity", "default": 0.7, "min": 0, "max": 1, "step": 0.05 },
    { "key": "visibility", "default": "visible", "options": ["visible", "none"] }
  ],
  "legend_config": {
    "type": "gradient",
    "items": [
      { "label": "Small population", "value": "@@#params.color" },
      { "label": "Large population", "value": "@@#params.color" }
    ]
  }
}
