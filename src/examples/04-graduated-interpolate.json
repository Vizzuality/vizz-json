{
  "metadata": {
    "title": "Expression — interpolate",
    "description": "Continuous color ramp for population using interpolate expression with parameterized stops",
    "tier": "intermediate"
  },
  "config": {
    "source": {
      "type": "geojson",
      "data": "https://d2ad6b4ur7yvpq.cloudfront.net/naturalearth-3.3.0/ne_50m_admin_0_countries.geojson"
    },
    "styles": [
      {
        "type": "fill",
        "paint": {
          "fill-color": [
            "interpolate",
            ["linear"],
            ["get", "pop_est"],
            "@@#params.threshold_1",
            "@@#params.color_1",
            "@@#params.threshold_2",
            "@@#params.color_2",
            "@@#params.threshold_3",
            "@@#params.color_3"
          ],
          "fill-opacity": "@@#params.opacity"
        },
        "layout": {
          "visibility": "@@#params.visibility"
        }
      }
    ]
  },
  "params_config": [
    {
      "key": "threshold_1",
      "default": 0,
      "min": 0,
      "max": 500000000,
      "step": 1000000,
      "group": "legend"
    },
    {
      "key": "threshold_2",
      "default": 50000000,
      "min": 0,
      "max": 1000000000,
      "step": 1000000,
      "group": "legend"
    },
    {
      "key": "threshold_3",
      "default": 500000000,
      "min": 0,
      "max": 2000000000,
      "step": 10000000,
      "group": "legend"
    },
    { "key": "color_1", "default": "#eff6ff", "group": "legend" },
    { "key": "color_2", "default": "#3b82f6", "group": "legend" },
    { "key": "color_3", "default": "#1e3a8a", "group": "legend" },
    { "key": "opacity", "default": 0.8, "min": 0, "max": 1, "step": 0.05 },
    {
      "key": "visibility",
      "default": "visible",
      "options": ["visible", "none"]
    }
  ],
  "legend_config": {
    "type": "gradient",
    "items": [
      { "label": "Low population", "value": "@@#params.color_1" },
      { "label": "Mid population", "value": "@@#params.color_2" },
      { "label": "High population", "value": "@@#params.color_3" }
    ]
  }
}
