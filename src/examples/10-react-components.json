{
  "metadata": {
    "title": "React Components — @@type Legend",
    "description": "Demonstrates @@type resolving to registered React components for legends",
    "tier": "advanced"
  },
  "config": {
    "source": {
      "type": "geojson",
      "data": "https://d2ad6b4ur7yvpq.cloudfront.net/naturalearth-3.3.0/ne_50m_admin_0_countries.geojson"
    },
    "styles": [
      {
        "type": "fill",
        "paint": {
          "fill-color": [
            "interpolate",
            ["linear"],
            ["get", "pop_est"],
            0,
            "@@#params.color_low",
            50000000,
            "@@#params.color_mid",
            500000000,
            "@@#params.color_high"
          ],
          "fill-opacity": "@@#params.opacity"
        },
        "layout": {
          "visibility": "@@#params.visibility"
        }
      }
    ]
  },
  "params_config": [
    { "key": "color_low", "default": "#eff6ff", "group": "legend" },
    { "key": "color_mid", "default": "#3b82f6", "group": "legend" },
    { "key": "color_high", "default": "#1e3a8a", "group": "legend" },
    { "key": "opacity", "default": 0.8, "min": 0, "max": 1, "step": 0.05 },
    { "key": "visibility", "default": "visible", "options": ["visible", "none"] },
    { "key": "legend_title", "default": "Population Density" },
    { "key": "show_legend", "default": true }
  ],
  "legend_config": {
    "type": "gradient",
    "items": [
      { "label": "Low", "value": "@@#params.color_low" },
      { "label": "High", "value": "@@#params.color_high" }
    ]
  }
}
